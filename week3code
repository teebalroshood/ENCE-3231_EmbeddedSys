/*
 * This gives a short delay in microseconds.
 * TIM5 is set so that 1 timer count = 1 us.
 */
void delay_us(uint16_t us)
{
    __HAL_TIM_SET_COUNTER(&htim5, 0);
    while (__HAL_TIM_GET_COUNTER(&htim5) < us);
}

/*
 * The HC-SR04 starts a measurement when TRIG receives a 10 us HIGH pulse.
 */
void HCSR04_Trigger(void)
{
    HAL_GPIO_WritePin(HCSR04_TRIG_PORT, HCSR04_TRIG_PIN, GPIO_PIN_RESET);
    delay_us(2);

    HAL_GPIO_WritePin(HCSR04_TRIG_PORT, HCSR04_TRIG_PIN, GPIO_PIN_SET);
    delay_us(10);

    HAL_GPIO_WritePin(HCSR04_TRIG_PORT, HCSR04_TRIG_PIN, GPIO_PIN_RESET);
}

/*
 * This interrupt callback runs when TIM5 captures an edge on PA0.
 *
 * First interrupt:
 *   ECHO goes HIGH -> save start time
 *
 * Second interrupt:
 *   ECHO goes LOW -> save end time
 *
 * The pulse width is then converted into distance.
 */
void HAL_TIM_IC_CaptureCallback(TIM_HandleTypeDef *htim)
{
    if (htim->Instance == TIM5 && htim->Channel == HAL_TIM_ACTIVE_CHANNEL_1)
    {
        if (Is_First_Captured == 0)
        {
            /* Rising edge captured */
            IC_Val1 = HAL_TIM_ReadCapturedValue(htim, TIM_CHANNEL_1);
            Is_First_Captured = 1;

            /* Next capture should be the falling edge */
            __HAL_TIM_SET_CAPTUREPOLARITY(htim, TIM_CHANNEL_1, TIM_INPUTCHANNELPOLARITY_FALLING);
        }
        else
        {
            /* Falling edge captured */
            IC_Val2 = HAL_TIM_ReadCapturedValue(htim, TIM_CHANNEL_1);

            /* Handle normal case and overflow case */
            if (IC_Val2 >= IC_Val1)
            {
                Difference = IC_Val2 - IC_Val1;
            }
            else
            {
                Difference = (0xFFFFFFFF - IC_Val1) + IC_Val2 + 1;
            }

            /* Convert pulse width in microseconds to distance in cm */
            Distance = Difference / 58.0f;

            /* Reset for next measurement */
            Is_First_Captured = 0;
            __HAL_TIM_SET_CAPTUREPOLARITY(htim, TIM_CHANNEL_1, TIM_INPUTCHANNELPOLARITY_RISING);

            /* Toggle an LED so you can see the interrupt is active */
            HAL_GPIO_TogglePin(GPIOD, GPIO_PIN_13);
        }
    }
}

